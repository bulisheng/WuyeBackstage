/* 图标样式 - 仅使用 Unicode 字符，不再加载字体文件 */
.iconfont {
  font-family: inherit;
  font-size: 16px;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

