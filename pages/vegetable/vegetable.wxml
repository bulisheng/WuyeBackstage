<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <text class="iconfont icon-back"></text>
      </view>
      <text class="nav-title">蔬菜代买</text>
    </view>
  </view>

  <view class="content">
    <!-- 服务说明 -->
    <view class="service-banner">
      <view class="banner-icon">
        <text class="iconfont icon-vegetable"></text>
      </view>
      <view class="banner-info">
        <text class="banner-title">蔬菜代买服务</text>
        <text class="banner-desc">新鲜蔬菜送到家，方便又省心</text>
      </view>
    </view>

    <!-- 今日特惠 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">今日特惠</text>
        <text class="section-more" bindtap="viewMore">更多 ></text>
      </view>
      <view class="discount-list">
        <view class="discount-item" wx:for="{{discountItems}}" wx:key="id">
          <view class="discount-img">
            <text class="iconfont icon-vegetable"></text>
          </view>
          <view class="discount-info">
            <text class="discount-name">{{item.name}}</text>
            <view class="discount-price">
              <text class="price">¥{{item.price}}</text>
              <text class="original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
            </view>
          </view>
          <view class="discount-tag">特惠</view>
        </view>
      </view>
    </view>

    <!-- 商品分类 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">商品分类</text>
      </view>
      <view class="category-grid">
        <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">
          <view class="category-icon {{item.color}}">
            <text class="iconfont {{item.icon}}"></text>
          </view>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 热门商品 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">热门商品</text>
        <text class="section-more" bindtap="viewMore">更多 ></text>
      </view>
      <view class="product-list">
        <view class="product-item" wx:for="{{products}}" wx:key="id">
          <view class="product-img">
            <text class="iconfont icon-vegetable"></text>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-desc">{{item.spec}}</text>
            <view class="product-bottom">
              <text class="product-price">¥{{item.price}}</text>
              <view class="product-action">
                <text class="add-btn" bindtap="addToCart" data-id="{{item.id}}">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 购物车悬浮按钮 -->
    <view class="cart-bar" bindtap="openCart">
      <view class="cart-icon">
        <text class="iconfont icon-cart"></text>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
      <view class="cart-info">
        <text class="cart-total">¥{{cartTotal}}</text>
      </view>
      <view class="cart-submit {{cartCount > 0 ? 'active' : ''}}" bindtap="submitOrder">
        去结算
      </view>
    </view>
  </view>
</view>
