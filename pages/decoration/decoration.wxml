<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <text class="iconfont icon-back"></text>
      </view>
      <text class="nav-title">装修登记</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 申请入口 -->
    <view class="apply-card" bindtap="showApplyModal">
      <view class="apply-icon">
        <text>🏠</text>
      </view>
      <view class="apply-info">
        <text class="apply-title">装修申请</text>
        <text class="apply-desc">提前登记，规范装修流程</text>
      </view>
      <view class="apply-btn">去申请</view>
    </view>

    <!-- 装修须知 -->
    <view class="notice-card">
      <view class="notice-header">
        <text class="notice-icon">📋</text>
        <text class="notice-title">装修须知</text>
      </view>
      <view class="notice-list">
        <view class="notice-item">
          <text class="notice-num">1</text>
          <text class="notice-text">装修前需提前3天申请</text>
        </view>
        <view class="notice-item">
          <text class="notice-num">2</text>
          <text class="notice-text">施工时间：周一至周五 9:00-18:00</text>
        </view>
        <view class="notice-item">
          <text class="notice-num">3</text>
          <text class="notice-text">节假日禁止噪音施工</text>
        </view>
        <view class="notice-item">
          <text class="notice-num">4</text>
          <text class="notice-text">押金2000元，验收后退还</text>
        </view>
      </view>
    </view>

    <!-- 申请记录 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">我的申请</text>
        <text class="section-count" wx:if="{{records.length > 0}}">{{records.length}}条</text>
      </view>
      
      <view class="record-list">
        <view class="record-card" wx:for="{{records}}" wx:key="id">
          <view class="card-header">
            <view class="card-type">
              <text class="type-icon">{{item.icon}}</text>
              <text class="type-name">{{item.decorationType}}</text>
            </view>
            <view class="card-status {{item.status}}">
              <view class="status-dot"></view>
              <text>{{item.statusText}}</text>
            </view>
          </view>
          
          <view class="card-content">
            <text>{{item.description || '装修申请'}}</text>
          </view>
          
          <view class="card-footer">
            <view class="card-info">
              <text class="info-item">
                <text class="iconfont icon-time"></text>
                {{item.applyDate}}
              </text>
              <text class="info-item" wx:if="{{item.status === 'approved'}}">
                <text class="iconfont icon-calendar"></text>
                {{item.startDate}} 至 {{item.endDate}}
              </text>
            </view>
          </view>

          <!-- 驳回原因 -->
          <view class="reject-reason" wx:if="{{item.status === 'rejected' && item.rejectReason}}">
            <text class="reject-icon">!</text>
            <text>{{item.rejectReason}}</text>
          </view>
        </view>

        <view class="empty-state" wx:if="{{records.length === 0}}">
          <view class="empty-icon">📝</view>
          <text class="empty-text">暂无装修申请</text>
          <text class="empty-sub">有装修需求随时申请</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 申请弹窗 -->
<view class="modal" wx:if="{{showModal}}" bindtap="hideModal">
  <view class="modal-content" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">装修申请</text>
      <text class="modal-close" bindtap="hideModal">×</text>
    </view>
    
    <scroll-view class="modal-body" scroll-y>
      <!-- 装修类型 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">🔧</text>
          <text>装修类型</text>
        </view>
        <view class="type-grid">
          <view 
            class="type-item {{formData.decorationType === item ? 'active' : ''}}" 
            wx:for="{{decorationTypes}}" 
            wx:key="index"
            bindtap="selectType"
            data-type="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <!-- 施工区域 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📍</text>
          <text>施工区域</text>
        </view>
        <view class="area-grid">
          <view 
            class="area-item {{formData.area === item ? 'active' : ''}}" 
            wx:for="{{areas}}" 
            wx:key="index"
            bindtap="selectArea"
            data-area="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <!-- 装修说明 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📝</text>
          <text>简单说明</text>
          <text class="label-tip">简单描述即可</text>
        </view>
        <textarea 
          class="textarea-field" 
          placeholder="比如：厨房橱柜翻新、卫生间防水..." 
          placeholder-class="placeholder"
          maxlength="100"
          value="{{formData.description}}"
          bindinput="onInput"
          data-field="description"
        ></textarea>
      </view>

      <!-- 施工时间 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📅</text>
          <text>预计时间</text>
        </view>
        <view class="time-row">
          <picker mode="date" start="{{minDate}}" bindchange="onStartDateChange">
            <view class="time-picker">
              <text class="{{formData.startDate ? 'has-value' : 'no-value'}}">{{formData.startDate || '开始日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
          <text class="time-divider">至</text>
          <picker mode="date" start="{{formData.startDate || minDate}}" bindchange="onEndDateChange">
            <view class="time-picker">
              <text class="{{formData.endDate ? 'has-value' : 'no-value'}}">{{formData.endDate || '结束日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 装修公司 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">🏢</text>
          <text>装修公司</text>
        </view>
        <input 
          class="input-field" 
          placeholder="请输入公司名称（选填）" 
          value="{{formData.company}}" 
          bindinput="onInput"
          data-field="company"
        />
      </view>

      <!-- 联系电话 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📞</text>
          <text>联系电话</text>
        </view>
        <input 
          class="input-field" 
          type="number" 
          placeholder="{{phone}}" 
          value="{{formData.phone}}" 
          bindinput="onInput"
          data-field="phone"
        />
        <view class="input-tip">来自账户信息</view>
      </view>

      <!-- 协议 -->
      <view class="agreement-row" bindtap="toggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link">《装修管理协议》</text>
      </view>
    </scroll-view>
    
    <view class="modal-footer">
      <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitApply">
        <text>提交申请</text>
      </view>
    </view>
  </view>
</view>
