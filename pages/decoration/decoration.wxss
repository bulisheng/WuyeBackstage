/* 装修登记页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #fa8c16 0%, #ffc53d 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

/* 内容区域 */
.content {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 申请卡片 */
.apply-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fa8c16 0%, #ffc53d 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(250, 140, 22, 0.3);
}

.apply-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.apply-info {
  flex: 1;
  margin-left: 24rpx;
}

.apply-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.apply-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.apply-btn {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #fa8c16;
  font-weight: 500;
}

/* 须知卡片 */
.notice-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.notice-num {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #fa8c16 0%, #ffc53d 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  flex-shrink: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 记录列表 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-type {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.type-icon {
  font-size: 32rpx;
}

.type-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.card-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.card-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.card-status.approved {
  background: #f6ffed;
  color: #52c41a;
}

.card-status.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.card-content {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-info {
  display: flex;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.info-item .iconfont {
  margin-right: 6rpx;
  font-size: 22rpx;
}

.reject-reason {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff1f0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}

.reject-icon {
  width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 90vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
  max-height: 65vh;
}

.modal-footer {
  padding: 20rpx 32rpx 40rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.input-label text:nth-child(2) {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.label-tip {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 类型选择 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.type-item {
  padding: 20rpx 16rpx;
  text-align: center;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #fff7e6;
  border-color: #fa8c16;
  color: #fa8c16;
  font-weight: 500;
}

/* 区域选择 */
.area-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.area-item {
  padding: 20rpx 16rpx;
  text-align: center;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.area-item.active {
  background: #fff7e6;
  border-color: #fa8c16;
  color: #fa8c16;
  font-weight: 500;
}

/* 文本域 */
.textarea-field {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea-field:focus {
  border-color: #fa8c16;
}

.placeholder {
  color: #b3b3b3;
  font-size: 28rpx;
}

/* 时间选择 */
.time-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.no-value {
  font-size: 28rpx;
  color: #b3b3b3;
}

.has-value {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.time-divider {
  font-size: 28rpx;
  color: #999;
}

/* 输入框 */
.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #fa8c16;
}

.input-tip {
  font-size: 22rpx;
  color: #52c41a;
  margin-top: 8rpx;
}

/* 协议 */
.agreement-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.checkbox.checked {
  background: #fa8c16;
  border-color: #fa8c16;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #fa8c16;
}

/* 提交按钮 */
.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #fa8c16 0%, #ffc53d 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(250, 140, 22, 0.3);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
