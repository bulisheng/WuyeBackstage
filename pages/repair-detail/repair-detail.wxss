.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.main-content {
  padding: 24rpx;
}

.detail-card {
  padding: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  margin-right: 20rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #fff7e6;
  color: #faad14;
}

.status-processing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-completed {
  background: #f6ffed;
  color: #52c41a;
}

.detail-body {
  margin-top: 30rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child {
  border-bottom: none;
}

.row-label {
  font-size: 28rpx;
  color: #999999;
}

.row-value {
  font-size: 28rpx;
  color: #333333;
}

.description-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.desc-label {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 进度跟踪 */
.progress-card {
  padding: 30rpx;
  margin-top: 24rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 30rpx;
}

.timeline {
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  padding-bottom: 40rpx;
  position: relative;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 30rpx;
  width: 2rpx;
  height: calc(100% - 20rpx);
  background: #e0e0e0;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-item.active::before {
  background: #52c41a;
}

.timeline-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-right: 20rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.timeline-item.active .timeline-dot {
  background: #52c41a;
}

.timeline-content {
  display: flex;
  flex-direction: column;
}

.timeline-title {
  font-size: 28rpx;
  color: #333333;
}

.timeline-item.active .timeline-title {
  color: #52c41a;
  font-weight: 500;
}

.timeline-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

/* 操作按钮 */
.action-section {
  margin-top: 40rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.cancel-btn {
  background: #ffffff;
  color: #666666;
  border: 2rpx solid #dddddd;
}

.contact-btn {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
}
