<view class="page">
  <view class="header">
    <view class="header-content">
      <text class="header-title">报修详情</text>
    </view>
  </view>

  <view class="main-content">
    <view class="detail-card card">
      <view class="detail-header">
        <text class="detail-title">{{repairItem.title}}</text>
        <view class="status-tag status-{{repairItem.status}}">
          <text>{{repairItem.statusText}}</text>
        </view>
      </view>

      <view class="detail-body">
        <view class="detail-row">
          <text class="row-label">报修类型</text>
          <text class="row-value">{{repairItem.type}}</text>
        </view>
        <view class="detail-row">
          <text class="row-label">提交时间</text>
          <text class="row-value">{{repairItem.createTime}}</text>
        </view>
        <view class="detail-row" wx:if="{{repairItem.completeTime}}">
          <text class="row-label">完成时间</text>
          <text class="row-value">{{repairItem.completeTime}}</text>
        </view>
      </view>

      <view class="description-section">
        <text class="desc-label">问题描述</text>
        <text class="desc-content">{{repairItem.description}}</text>
      </view>
    </view>

    <!-- 进度跟踪 -->
    <view class="progress-card card" wx:if="{{repairItem.status !== 'completed'}}">
      <text class="progress-title">处理进度</text>
      <view class="timeline">
        <view class="timeline-item active">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <text class="timeline-title">已提交</text>
            <text class="timeline-time">{{repairItem.createTime}}</text>
          </view>
        </view>
        <view class="timeline-item active">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <text class="timeline-title">维修中</text>
            <text class="timeline-time">维修人员已接单</text>
          </view>
        </view>
        <view class="timeline-item">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <text class="timeline-title">待完成</text>
            <text class="timeline-time">等待维修完成</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button class="action-btn cancel-btn" wx:if="{{repairItem.status === 'pending'}}" bindtap="cancelRepair">
        取消报修
      </button>
      <button class="action-btn contact-btn" bindtap="contactService">
        联系物业
      </button>
    </view>
  </view>
</view>
