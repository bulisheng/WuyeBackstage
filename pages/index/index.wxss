/* 首页样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 内容区域 */
.content {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 调试信息 */
.debug-panel {
  background: linear-gradient(135deg, #102a43 0%, #1e3a5f 100%);
  border-radius: 18rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 30rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 42, 67, 0.18);
}

.debug-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.debug-panel-title {
  font-size: 30rpx;
  font-weight: 600;
}

.debug-panel-tag {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
}

.debug-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 14rpx;
}

.debug-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
  flex-shrink: 0;
}

.debug-value {
  font-size: 24rpx;
  color: #fff;
  text-align: right;
  word-break: break-all;
}

.debug-url {
  font-family: monospace;
}

.debug-actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.debug-copy-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
  font-size: 24rpx;
}

/* 通知公告 */
.notice-banner {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.notice-icon {
  width: 56rpx;
  height: 56rpx;
  background: #fff1e6;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-icon .iconfont {
  color: #ff6b00;
  font-size: 32rpx;
}

.notice-swiper {
  flex: 1;
  height: 56rpx;
  overflow: hidden;
}

.notice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 56rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-text.important {
  color: #ff4d4f;
  font-weight: 500;
}

.more-arrow {
  color: #999;
  font-size: 28rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 快捷入口 */
.quick-entry {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.entry-icon .iconfont {
  font-size: 48rpx;
  color: #fff;
}

.entry-icon.bg-blue {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.entry-icon.bg-green {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.entry-icon.bg-orange {
  background: linear-gradient(135deg, #ff6b00 0%, #ffa940 100%);
}

.entry-icon.bg-purple {
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
}

.entry-icon.bg-orange-dark {
  background: linear-gradient(135deg, #fa8c16 0%, #ffc53d 100%);
}

.entry-icon.bg-blue-dark {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.entry-icon.bg-green-light {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.entry-title {
  font-size: 24rpx;
  color: #333;
}

/* 更多服务 */
.service-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.service-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.service-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.service-emoji {
  font-size: 38rpx;
  line-height: 1;
}

.service-icon.bg-orange {
  background: linear-gradient(135deg, #ff6b00 0%, #ffa940 100%);
}

.service-icon.bg-red {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
}

.service-icon.bg-blue-dark {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.service-icon.bg-gray {
  background: linear-gradient(135deg, #666 0%, #999 100%);
}

.service-icon.bg-ai {
  background: linear-gradient(135deg, #5c6cff 0%, #2dd4bf 100%);
}

.service-name {
  font-size: 24rpx;
  color: #333;
}

/* 小区信息卡片 */
.community-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.community-info {
  display: flex;
  align-items: center;
}

.community-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.community-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.community-detail {
  display: flex;
  flex-direction: column;
}

.community-name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.community-address {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 通用区块 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #1890ff;
}

/* 账单卡片 */
.bill-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.bill-info {
  display: flex;
  align-items: center;
}

.bill-type {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  background: #e6f7ff;
}

.bill-type.property {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.bill-type.water {
  background: linear-gradient(135deg, #13c2c2 0%, #5cdbd3 100%);
}

.bill-type.electricity {
  background: linear-gradient(135deg, #faad14 0%, #ffd666 100%);
}

.bill-detail {
  display: flex;
  flex-direction: column;
}

.bill-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.bill-period {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.bill-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.bill-amount {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.bill-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 8rpx;
}

.bill-status.unpaid {
  background: #fff1e6;
  color: #ff6b00;
}

/* 房屋信息卡片 */
.house-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.house-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.house-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.house-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.house-detail {
  display: flex;
  flex-direction: column;
}

.house-room {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.house-address {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.house-status {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.status-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-value {
  font-size: 28rpx;
  font-weight: bold;
}

.status-value.normal {
  color: #52c41a;
}

.status-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 报修卡片 */
.repair-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.repair-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.repair-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.repair-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.repair-status.processing {
  background: #e6f7ff;
  color: #1890ff;
}

.repair-status.completed {
  background: #f6ffed;
  color: #52c41a;
}

.repair-info {
  display: flex;
  flex-direction: column;
}

.repair-time,
.repair-handler {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 小区概览 */
.overview-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
