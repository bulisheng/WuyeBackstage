<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <text class="iconfont icon-back"></text>
      </view>
      <text class="nav-title">我的</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-info">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="user-detail">
          <text class="user-name">{{userInfo.name}}</text>
          <text class="user-room">{{userInfo.room}}</text>
        </view>
      </view>
      <view class="edit-btn" bindtap="editInfo">
        <text class="iconfont icon-edit"></text>
        <text>编辑</text>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item" bindtap="goToPayment">
        <text class="stat-value">{{unpaidCount}}</text>
        <text class="stat-label">待缴账单</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goToRepair">
        <text class="stat-value">{{repairCount}}</text>
        <text class="stat-label">报修记录</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goToNotice">
        <text class="stat-value">{{noticeCount}}</text>
        <text class="stat-label">未读公告</text>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="goToPayment">
        <view class="menu-left">
          <view class="menu-icon bg-blue">
            <text class="iconfont icon-payment"></text>
          </view>
          <text class="menu-text">物业缴费</text>
        </view>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{unpaidCount > 0}}">{{unpaidCount}} 待支付</text>
          <text class="arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="goToRepair">
        <view class="menu-left">
          <view class="menu-icon bg-green">
            <text class="iconfont icon-repair"></text>
          </view>
          <text class="menu-text">报修记录</text>
        </view>
        <view class="menu-right">
          <text class="arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="goToNotice">
        <view class="menu-left">
          <view class="menu-icon bg-orange">
            <text class="iconfont icon-notice"></text>
          </view>
          <text class="menu-text">小区公告</text>
        </view>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{noticeCount > 0}}">{{noticeCount}} 未读</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-item" bindtap="contactProperty">
        <view class="menu-left">
          <view class="menu-icon bg-purple">
            <text class="iconfont icon-phone"></text>
          </view>
          <text class="menu-text">联系物业</text>
        </view>
        <view class="menu-right">
          <text class="menu-value">{{communityInfo.propertyPhone}}</text>
          <text class="arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="goToFeedback">
        <view class="menu-left">
          <view class="menu-icon bg-cyan">
            <text class="iconfont icon-feedback"></text>
          </view>
          <text class="menu-text">意见反馈</text>
        </view>
        <view class="menu-right">
          <text class="arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="goToAbout">
        <view class="menu-left">
          <view class="menu-icon bg-gray">
            <text class="iconfont icon-about"></text>
          </view>
          <text class="menu-text">关于我们</text>
        </view>
        <view class="menu-right">
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <!-- 物业信息 -->
    <view class="property-card">
      <view class="property-header">
        <text class="property-title">物业服务中心</text>
      </view>
      <view class="property-info">
        <view class="info-row">
          <text class="info-label">物业名称</text>
          <text class="info-value">{{communityInfo.propertyCompany}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">服务电话</text>
          <text class="info-value phone" bindtap="contactProperty">{{communityInfo.propertyPhone}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">办公地址</text>
          <text class="info-value">{{communityInfo.address}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">服务时间</text>
          <text class="info-value">周一至周日 9:00-18:00</text>
        </view>
      </view>
    </view>
  </view>
</view>
