<view class="page">
  <view class="header">
    <view class="header-content">
      <text class="header-title">投诉建议</text>
    </view>
  </view>

  <view class="main-content">
    <!-- 新建投诉按钮 -->
    <view class="new-complaint-btn card" bindtap="showNewComplaint">
      <view class="new-complaint-icon">✉</view>
      <view class="new-complaint-info">
        <text class="new-complaint-title">提交投诉建议</text>
        <text class="new-complaint-desc">您的意见是我们改进的动力</text>
      </view>
    </view>

    <!-- 投诉建议列表 -->
    <view class="complaint-section">
      <view class="section-header">
        <text class="section-title">我的记录</text>
        <text class="section-count">{{complaintList.length}}条</text>
      </view>

      <view class="complaint-list">
        <view class="complaint-item card" 
              wx:for="{{complaintList}}" 
              wx:key="id">
          <view class="complaint-header">
            <text class="complaint-title">{{item.title}}</text>
            <view class="complaint-status status-{{item.status}}">
              <text>{{item.statusText}}</text>
            </view>
          </view>
          <view class="complaint-body">
            <view class="complaint-info-row">
              <text class="info-label">类型</text>
              <text class="info-value">{{item.type}}</text>
            </view>
            <view class="complaint-info-row">
              <text class="info-label">时间</text>
              <text class="info-value">{{item.createTime}}</text>
            </view>
            <view class="complaint-info-row">
              <text class="info-label">内容</text>
              <text class="info-value content">{{item.description}}</text>
            </view>
          </view>
          
          <!-- 回复内容 -->
          <view class="reply-section" wx:if="{{item.reply}}">
            <view class="reply-header">
              <text class="reply-title">物业回复</text>
              <text class="reply-time">{{item.replyTime}}</text>
            </view>
            <text class="reply-content">{{item.reply}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 新建投诉弹窗 -->
  <view class="modal-mask {{showModal ? 'show' : ''}}" bindtap="hideModal">
    <view class="modal-content {{showModal ? 'show' : ''}}" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">提交投诉建议</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">投诉类型</text>
          <picker mode="selector" range="{{complaintTypes}}" bindchange="onTypeChange">
            <view class="picker-value">
              {{complaintTypes[selectedType]}}
              <text class="arrow-down">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">标题</text>
          <input class="form-input" placeholder="请输入标题" bindinput="onTitleInput" value="{{formData.title}}"/>
        </view>

        <view class="form-item">
          <text class="form-label">详细内容</text>
          <textarea class="form-textarea" placeholder="请详细描述您的问题或建议" bindinput="onDescInput" value="{{formData.description}}"></textarea>
        </view>

        <view class="form-item">
          <text class="form-label">联系电话</text>
          <input class="form-input" type="number" placeholder="请输入联系电话" bindinput="onPhoneInput" value="{{formData.phone}}"/>
        </view>
      </view>

      <view class="modal-footer">
        <button class="submit-btn" bindtap="submitComplaint">提交</button>
      </view>
    </view>
  </view>
</view>
