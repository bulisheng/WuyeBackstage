.assistant-page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 16rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top left, rgba(91, 140, 255, 0.16), transparent 34%),
    radial-gradient(circle at top right, rgba(45, 212, 191, 0.12), transparent 28%),
    linear-gradient(180deg, #f6f8ff 0%, #f3f6fb 100%);
}

.card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(70, 95, 160, 0.08);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(18, 38, 84, 0.08);
  backdrop-filter: blur(12px);
}

.assistant-head {
  padding: 4rpx 8rpx 10rpx;
}

.assistant-head-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  color: #172b4d;
  font-weight: 700;
}

.assistant-head-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #66708b;
}

.assistant-hero {
  position: relative;
  overflow: hidden;
  min-height: 220rpx;
  margin-bottom: 12rpx;
  border-radius: 28rpx;
}

.assistant-hero-image {
  width: 100%;
  height: 220rpx;
  display: block;
}

.assistant-hero-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx 22rpx 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(242, 247, 255, 0.16) 100%);
}

.assistant-hero-copy {
  width: 68%;
}

.assistant-hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #14213d;
  letter-spacing: 1rpx;
}

.assistant-hero-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #54607c;
}

.assistant-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.assistant-hero-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #16325c;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(59, 91, 253, 0.12);
  backdrop-filter: blur(10px);
}

.section {
  margin-bottom: 10rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #172b4d;
}

.section-more {
  font-size: 22rpx;
  color: #3b5bfd;
}

.context-card {
  padding: 22rpx;
}

.context-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.context-item {
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f7f9ff;
}

.context-label {
  display: block;
  font-size: 20rpx;
  color: #7b86a8;
}

.context-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1c2a4d;
}

.context-note,
.session-note {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f5f7fb;
  color: #586580;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}

.session-label {
  display: block;
  margin-bottom: 8rpx;
  color: #8d95b0;
}

.session-url {
  display: block;
  color: #304878;
  font-family: monospace;
}

.chat-panel {
  flex: 1;
  min-height: 0;
  height: 58vh;
  padding: 12rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.assistant-loading {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 8rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(59, 91, 253, 0.12);
}

.assistant-loading-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.assistant-loading-dot-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.assistant-loading-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3b5bfd 0%, #2dd4bf 100%);
  box-shadow: 0 0 0 10rpx rgba(59, 91, 253, 0.08);
  animation: assistant-loading-pulse 1.4s ease-in-out infinite;
}

.assistant-loading-dot-delay {
  animation-delay: 0.18s;
}

.assistant-loading-dot-delay-2 {
  animation-delay: 0.36s;
}

.assistant-loading-head-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.assistant-loading-texts {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.assistant-loading-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #172b4d;
}

.assistant-loading-subtitle {
  display: block;
  font-size: 20rpx;
  color: #66708b;
}

.assistant-loading-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #f6f8ff;
}

.assistant-loading-step.done {
  background: #eefaf4;
}

.assistant-loading-step.active {
  background: linear-gradient(90deg, rgba(59, 91, 253, 0.1), rgba(45, 212, 191, 0.12));
}

.assistant-loading-step-index {
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #3b5bfd;
  background: #fff;
  box-shadow: inset 0 0 0 1rpx rgba(59, 91, 253, 0.18);
  flex-shrink: 0;
}

.assistant-loading-step.done .assistant-loading-step-index {
  color: #0f9b5f;
  box-shadow: inset 0 0 0 1rpx rgba(15, 155, 95, 0.18);
}

.assistant-loading-step.active .assistant-loading-step-index {
  color: #0d4ed8;
  box-shadow: inset 0 0 0 1rpx rgba(13, 78, 216, 0.22);
}

.assistant-loading-step-texts {
  flex: 1;
  min-width: 0;
}

.assistant-loading-step-title {
  display: block;
  font-size: 23rpx;
  font-weight: 700;
  color: #172b4d;
}

.assistant-loading-step-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 19rpx;
  color: #66708b;
}

.assistant-loading-step-status {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #3b5bfd;
}

@keyframes assistant-loading-pulse {
  0%,
  100% {
    transform: translateY(0);
    opacity: 0.55;
  }
  50% {
    transform: translateY(-3rpx);
    opacity: 1;
  }
}

.message {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant,
.message.system {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 86%;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(20, 34, 68, 0.08);
}

.message.user .message-bubble {
  background: linear-gradient(135deg, #3b5bfd 0%, #2dd4bf 100%);
  color: #fff;
}

.message.system .message-bubble {
  background: #f0f4fb;
}

.message-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(20, 34, 68, 0.12);
}

.message-avatar.user {
  background: linear-gradient(135deg, #3b5bfd 0%, #2dd4bf 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #0f172a 0%, #3b5bfd 100%);
}

.message-avatar.system {
  background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
}

.message-avatar-text {
  font-size: 24rpx;
}

.message-meta {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.message-role {
  font-size: 20rpx;
  font-weight: 600;
}

.message-time {
  font-size: 20rpx;
  color: inherit;
  opacity: 0.72;
}

.message-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
}

.message-card {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.28);
}

.card-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
}

.card-line {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.6;
}

.message-meta-line {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.meta-pill {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(59, 91, 253, 0.1);
  color: #3653a4;
  font-size: 20rpx;
}

.draft-card {
  padding: 20rpx 22rpx;
  margin-top: 8rpx;
}

.draft-body {
  margin-top: 8rpx;
}

.draft-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #172b4d;
}

.draft-line {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #57627f;
  line-height: 1.6;
}

.draft-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.draft-primary,
.draft-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.draft-primary {
  background: linear-gradient(135deg, #3b5bfd 0%, #2dd4bf 100%);
  color: #fff;
}

.draft-secondary {
  background: #eef2ff;
  color: #53638f;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 10rpx;
  margin-top: 4rpx;
}

.assistant-input {
  flex: 1;
  min-height: 58rpx;
  background: #f7f9ff;
  border-radius: 16rpx;
  padding: 0 16rpx;
  font-size: 21rpx;
  box-sizing: border-box;
}

.send-btn {
  min-width: 82rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #3b5bfd 0%, #2dd4bf 100%);
  color: #fff;
  font-size: 19rpx;
  padding: 0 10rpx;
}

.send-btn::after {
  border: none;
}
