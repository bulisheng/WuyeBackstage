<view class="container assistant-page">
  <view class="assistant-hero card">
    <image class="assistant-hero-image" src="/assets/images/assistant-hero.png" mode="aspectFill" />
    <view class="assistant-hero-overlay">
      <view class="assistant-hero-copy">
        <text class="assistant-hero-title">智能助手</text>
        <text class="assistant-hero-subtitle">查物业费、查报修、提报修、提投诉，先给结论，再办事。</text>
      </view>
      <view class="assistant-hero-tags">
        <text class="assistant-hero-tag">{{contextCard.communityName}}</text>
        <text class="assistant-hero-tag">{{contextCard.houseNo}}</text>
      </view>
    </view>
  </view>

  <scroll-view class="chat-panel card" scroll-y scroll-with-animation scroll-into-view="{{scrollIntoView}}">
    <block wx:for="{{messages}}" wx:key="id">
      <view class="message {{item.messageClass}}" id="{{item.id}}">
        <view class="message-avatar {{item.avatarClass}}" wx:if="{{item.showAvatar}}">
          <text class="message-avatar-text">{{item.avatarText}}</text>
        </view>
        <view class="message-bubble">
          <text class="message-text">{{item.text}}</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="draft-card card" wx:if="{{draftCard}}">
    <view class="section-header">
      <text class="section-title">待确认草稿</text>
      <text class="section-more" bindtap="cancelDraft">取消</text>
    </view>
    <view class="draft-body">
      <text class="draft-title">{{draftCard.title}}</text>
      <text class="draft-line">分类：{{draftCard.category}}</text>
      <text class="draft-line">{{draftCard.suggestion}}</text>
    </view>
    <view class="draft-actions">
      <view class="draft-primary" bindtap="confirmDraft">{{draftCard.buttonText}}</view>
      <view class="draft-secondary" bindtap="cancelDraft">稍后再说</view>
    </view>
  </view>

  <view class="input-bar card">
    <input
      class="assistant-input"
      placeholder="请输入你的问题，例如：查本月物业费"
      value="{{inputText}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" type="primary" bindtap="sendMessage" loading="{{loading}}">发送</button>
  </view>
</view>
