<view class="container assistant-page">
  <view class="assistant-head">
    <text class="assistant-head-title">智能助手</text>
    <text class="assistant-head-subtitle">优先回答当前小区和当前房屋的问题，涉及报修和投诉时先生成草稿再确认。</text>
  </view>

  <scroll-view class="chat-panel card" scroll-y>
    <block wx:for="{{messages}}" wx:key="time">
      <view class="message {{item.messageClass}}">
        <view class="message-bubble">
          <view class="message-meta">
            <text class="message-role">{{item.roleLabel}}</text>
            <text class="message-time">{{item.time}}</text>
          </view>
          <text class="message-text">{{item.text}}</text>
          <view class="message-card" wx:if="{{item.showCard}}">
            <text class="card-title">{{item.card.title}}</text>
            <text class="card-line" wx:if="{{item.showAmount}}">金额：¥{{item.card.amount}}</text>
            <text class="card-line" wx:if="{{item.showPeriod}}">周期：{{item.card.period}}</text>
            <text class="card-line" wx:if="{{item.showStatus}}">状态：{{item.card.status}}</text>
            <text class="card-line" wx:if="{{item.showStatusName}}">状态：{{item.card.statusName}}</text>
            <text class="card-line" wx:if="{{item.showHandler}}">处理人：{{item.card.handler}}</text>
            <text class="card-line" wx:if="{{item.showSuggestion}}">建议：{{item.card.suggestion}}</text>
          </view>
          <view class="message-meta-line" wx:if="{{item.showMeta}}">
            <text class="meta-pill">意图：{{item.intentText}}</text>
            <text class="meta-pill">置信度：{{item.confidenceText}}</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="assistant-loading card" wx:if="{{loading}}">
    <view class="assistant-loading-dot"></view>
    <view class="assistant-loading-texts">
      <text class="assistant-loading-title">智能助手正在思考</text>
      <text class="assistant-loading-subtitle">请稍候，正在连接 openclaw 并整理回复。</text>
    </view>
  </view>

  <view class="draft-card card" wx:if="{{draftCard}}">
    <view class="section-header">
      <text class="section-title">待确认草稿</text>
      <text class="section-more" bindtap="cancelDraft">取消</text>
    </view>
    <view class="draft-body">
      <text class="draft-title">{{draftCard.title}}</text>
      <text class="draft-line">分类：{{draftCard.category}}</text>
      <text class="draft-line">{{draftCard.suggestion}}</text>
    </view>
    <view class="draft-actions">
      <view class="draft-primary" bindtap="confirmDraft">{{draftCard.buttonText}}</view>
      <view class="draft-secondary" bindtap="cancelDraft">稍后再说</view>
    </view>
  </view>

  <view class="input-bar card">
    <input
      class="assistant-input"
      placeholder="请输入你的问题，例如：查本月物业费"
      value="{{inputText}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" type="primary" bindtap="sendMessage" loading="{{loading}}">发送</button>
  </view>

  <view class="section quick-service-section">
    <view class="section-header">
      <text class="section-title">快捷服务</text>
      <text class="section-more">一键办理</text>
    </view>
    <view class="service-grid compact-service-grid">
      <block wx:for="{{serviceCards}}" wx:key="id">
        <view class="service-card compact-service-card tone-{{item.tone}}" bindtap="tapServiceCard" data-text="{{item.text}}">
          <text class="service-card-title">{{item.title}}</text>
          <text class="service-card-subtitle">{{item.subtitle}}</text>
        </view>
      </block>
    </view>
  </view>
</view>
