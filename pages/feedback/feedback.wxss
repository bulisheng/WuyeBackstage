/* 投诉表扬页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 40rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #ff4d4f;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #ff4d4f;
  border-radius: 3rpx;
}

.tab-text {
  font-size: 30rpx;
}

.tab-badge {
  min-width: 36rpx;
  height: 36rpx;
  background: #ff4d4f;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  padding: 0 10rpx;
}

/* 内容区域 */
.tab-content {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 快速投诉卡片 */
.quick-card {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 79, 0.3);
}

.quick-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.quick-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.quick-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.quick-item:active {
  background: rgba(255, 255, 255, 0.3);
}

.item-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.item-text {
  font-size: 24rpx;
  color: #fff;
}

/* 表扬卡片 */
.praise-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

.praise-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.praise-info {
  flex: 1;
  margin-left: 24rpx;
}

.praise-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.praise-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.praise-btn {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #52c41a;
  font-weight: 500;
}

/* 记录列表 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-type {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.type-icon {
  font-size: 32rpx;
}

.type-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.record-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.record-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.record-status.processing {
  background: #e6f7ff;
  color: #1890ff;
}

.record-status.completed {
  background: #f6ffed;
  color: #52c41a;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.record-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.record-footer {
  display: flex;
  justify-content: flex-end;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

.record-reply {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f6ffed;
  border-radius: 12rpx;
}

.reply-icon {
  font-size: 28rpx;
}

.reply-text {
  font-size: 24rpx;
  color: #52c41a;
  line-height: 1.5;
}

/* 表扬列表 */
.praise-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.praise-card-item {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
}

.praise-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.praise-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.praise-info-row {
  margin-left: 16rpx;
}

.praise-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.praise-position {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.praise-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.praise-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.praise-from {
  font-size: 22rpx;
  color: #999;
}

.praise-time {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
  max-height: 55vh;
}

.modal-footer {
  padding: 20rpx 32rpx 40rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.input-label text:nth-child(2) {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.label-tip {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #ff4d4f;
}

.textarea-field {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea-field:focus {
  border-color: #ff4d4f;
}

.placeholder {
  color: #b3b3b3;
  font-size: 28rpx;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 79, 0.3);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
