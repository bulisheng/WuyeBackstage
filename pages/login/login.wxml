<view class="container">
  <!-- 顶部装饰 -->
  <view class="top-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
  </view>

  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-wrapper">
      <text class="logo-icon">🏠</text>
    </view>
    <text class="app-name">盛兴物业</text>
    <text class="app-slogan">便捷生活，从这里开始</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 手机号输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">📱</text>
        <text class="label-text">手机号</text>
      </view>
      <view class="input-wrapper">
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入手机号" 
          placeholder-class="placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
        <view class="input-clear" bindtap="clearPhone" wx:if="{{phone.length > 0}}">
          <text class="clear-icon">×</text>
        </view>
      </view>
      <view class="form-tip" wx:if="{{phoneError}}">
        <text class="error-text">{{phoneError}}</text>
      </view>
    </view>

    <!-- 验证码输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">🔐</text>
        <text class="label-text">验证码</text>
      </view>
      <view class="input-wrapper code-wrapper">
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入验证码" 
          placeholder-class="placeholder"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view class="code-btn {{codeDisabled ? 'disabled' : ''}}" bindtap="sendCode">
          <text>{{codeText}}</text>
        </view>
      </view>
      <view class="form-tip" wx:if="{{codeError}}">
        <text class="error-text">{{codeError}}</text>
      </view>
    </view>

    <!-- 自动归属提示 -->
    <view class="auto-match-tip">
      <text class="auto-match-title">自动匹配房屋</text>
      <text class="auto-match-text">输入手机号和验证码后，系统会按后台配置自动匹配对应的小区、楼栋、单元和房号。</text>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn-wrapper">
      <view class="login-btn {{canLogin ? '' : 'disabled'}}" bindtap="doLogin">
        <text class="btn-text">立即登录</text>
      </view>
    </view>

    <!-- 协议 -->
    <view class="agreement">
      <view class="checkbox-wrapper" bindtap="toggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{agreed}}">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意</text>
      </view>
      <text class="link-text" bindtap="showAgreement">《用户服务协议》</text>
      <text class="agreement-text">和</text>
      <text class="link-text" bindtap="showPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 协议弹窗 -->
  <view class="modal" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{modalTitle}}</text>
        <view class="modal-close" bindtap="hideModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <text class="modal-text">{{modalContent}}</text>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-btn" bindtap="hideModal">
          <text>我已阅读</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 房屋选择弹窗 -->
  <view class="modal" wx:if="{{showHouseSelector}}" bindtap="hideHouseSelector">
    <view class="modal-content house-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">请选择房屋</text>
        <view class="modal-close" bindtap="hideHouseSelector">×</view>
      </view>
      <view class="house-hint">{{houseSelectionHint}}</view>
      <scroll-view class="house-list" scroll-y>
        <view class="house-option" wx:for="{{houseOptions}}" wx:key="id" data-id="{{item.id}}" bindtap="selectHouseOption">
          <view class="house-option-main">
            <text class="house-option-title">{{item.label}}</text>
            <text class="house-option-detail">{{item.detail}}</text>
          </view>
          <text class="house-option-arrow">›</text>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-btn ghost" bindtap="hideHouseSelector">
          <text>取消</text>
        </view>
      </view>
    </view>
  </view>
</view>
