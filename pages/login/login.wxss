/* 登录页面样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4ff 0%, #f0f7ff 50%, #ffffff 100%);
  position: relative;
  overflow-x: hidden;
}

/* 顶部装饰 */
.top-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.1) 0%, rgba(24, 144, 255, 0.05) 100%);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -200rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  left: -150rpx;
}

/* Logo区域 */
.logo-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 60rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(24, 144, 255, 0.3);
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-top: 30rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 表单区域 */
.form-section {
  position: relative;
  margin: 0 30rpx;
  padding: 40rpx 40rpx 60rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* 表单项 */
.form-item {
  margin-bottom: 36rpx;
}

.auto-match-tip {
  margin-top: 8rpx;
  padding: 24rpx 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.08) 0%, rgba(22, 119, 255, 0.04) 100%);
  border: 1rpx solid rgba(24, 144, 255, 0.12);
}

.auto-match-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.auto-match-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  transition: border-color 0.3s;
}

.input-wrapper:focus-within {
  border-color: #1890ff;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  height: 44rpx;
  line-height: 44rpx;
}

.placeholder {
  color: #b3b3b3;
  font-size: 28rpx;
}

.input-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d9d9d9;
  border-radius: 50%;
  margin-left: 16rpx;
}

.clear-icon {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

/* 验证码输入 */
.code-wrapper {
  justify-content: space-between;
}

.code-wrapper .form-input {
  width: 260rpx;
}

.code-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #fff;
  white-space: nowrap;
}

.code-btn.disabled {
  background: #d9d9d9;
  color: #999;
}

.form-tip {
  margin-top: 12rpx;
}

.error-text {
  font-size: 24rpx;
  color: #ff4d4f;
}

/* 房屋信息表单 */
.house-form {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 8rpx 0;
}

.house-row {
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.house-row:last-child {
  border-bottom: none;
}

.house-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-label {
  font-size: 28rpx;
  color: #666;
  min-width: 100rpx;
}

.field-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
  margin-left: 30rpx;
  padding: 8rpx 0;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #b3b3b3;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.field-input-wrapper {
  display: flex;
  align-items: center;
  flex: 1;
  margin-left: 30rpx;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  padding: 8rpx 0;
}

.field-unit {
  font-size: 28rpx;
  color: #666;
  margin-left: 8rpx;
}

/* 登录按钮 */
.login-btn-wrapper {
  margin-top: 48rpx;
}

.login-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.login-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 32rpx;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  margin-right: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.check-icon {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.link-text {
  font-size: 24rpx;
  color: #1890ff;
}

/* 协议弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.house-modal {
  max-height: 78vh;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
  max-height: 400rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.modal-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

.modal-btn.ghost {
  background: #f4f7fb;
}

.modal-btn.ghost text {
  color: #333;
}

.house-hint {
  padding: 0 30rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.house-list {
  max-height: 460rpx;
  padding: 0 24rpx 20rpx;
}

.house-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
  border: 1rpx solid rgba(24, 144, 255, 0.12);
}

.house-option-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.house-option-title {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 700;
}

.house-option-detail {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}

.house-option-arrow {
  font-size: 40rpx;
  color: #94a3b8;
  padding-left: 16rpx;
}

/* 选择器弹窗 */
.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.picker-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.picker-confirm {
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 30rpx;
}

.picker-confirm text {
  font-size: 26rpx;
  color: #fff;
}

.picker-view {
  height: 400rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}
