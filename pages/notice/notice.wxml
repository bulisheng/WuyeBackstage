<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <text class="iconfont icon-back"></text>
      </view>
      <text class="nav-title">小区公告</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <view class="notice-list">
      <view class="notice-item" wx:for="{{notices}}" wx:key="id" bindtap="showDetail" data-index="{{index}}">
        <view class="notice-header">
          <view class="notice-badge {{item.important ? 'important' : ''}}" wx:if="{{item.important}}">
            <text>重要</text>
          </view>
          <text class="notice-title">{{item.title}}</text>
        </view>
        <view class="notice-footer">
          <text class="notice-time">{{item.time}}</text>
          <text class="notice-arrow">></text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{notices.length === 0}}">
        <view class="empty-icon">
          <text class="iconfont icon-empty"></text>
        </view>
        <text class="empty-text">暂无公告</text>
      </view>
    </view>
  </view>

  <!-- 公告详情弹窗 -->
  <view class="detail-modal {{showModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="hideDetail"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{currentNotice.title}}</text>
        <view class="modal-close" bindtap="hideDetail">
          <text class="iconfont icon-close"></text>
        </view>
      </view>
      <view class="modal-body">
        <text class="modal-time">{{currentNotice.time}}</text>
        <view class="modal-divider"></view>
        <text class="modal-text">{{currentNotice.content}}</text>
      </view>
    </view>
  </view>
</view>
