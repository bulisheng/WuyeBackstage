/* 账单详情页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

/* 内容区域 */
.content {
  padding: 30rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 30rpx;
}

.status-card.paid {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.status-icon .iconfont {
  font-size: 50rpx;
  color: #fff;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.status-time {
  font-size: 26rpx;
  opacity: 0.8;
  display: block;
  margin-top: 10rpx;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-header {
  display: flex;
  align-items: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.bill-type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.bill-type-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.bill-type-icon.property {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.bill-type-icon.water {
  background: linear-gradient(135deg, #13c2c2 0%, #5cdbd3 100%);
}

.bill-type-icon.electricity {
  background: linear-gradient(135deg, #faad14 0%, #ffd666 100%);
}

.bill-info {
  display: flex;
  flex-direction: column;
}

.bill-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.bill-room {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 费用明细卡片 */
.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.detail-list {
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 24rpx;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-left {
  display: flex;
  align-items: center;
}

.detail-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.detail-icon .iconfont {
  font-size: 24rpx;
  color: #fff;
}

.detail-icon.property {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.detail-icon.water {
  background: linear-gradient(135deg, #13c2c2 0%, #5cdbd3 100%);
}

.detail-icon.electricity {
  background: linear-gradient(135deg, #faad14 0%, #ffd666 100%);
}

.detail-name {
  font-size: 28rpx;
  color: #333;
}

.detail-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 支付方式卡片 */
.payment-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.payment-header {
  margin-bottom: 24rpx;
}

.payment-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #fafafa;
}

.payment-item.selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.payment-left {
  display: flex;
  align-items: center;
}

.payment-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.payment-icon .iconfont {
  font-size: 32rpx;
  color: #fff;
}

.payment-icon.wechat {
  background: linear-gradient(135deg, #07c160 0%, #4cd964 100%);
}

.payment-name {
  font-size: 28rpx;
  color: #333;
}

/* 温馨提示卡片 */
.tips-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-header {
  margin-bottom: 20rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-item {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  display: flex;
  flex-direction: column;
  margin-right: 30rpx;
}

.total-info .total-label {
  font-size: 24rpx;
  color: #999;
}

.total-info .total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.pay-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
