/* 缴费页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 内容区域 */
.content {
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

/* 账单概览卡片 */
.overview-card {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.overview-title {
  font-size: 28rpx;
  opacity: 0.9;
}

.overview-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
}

.overview-amount {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.currency {
  font-size: 36rpx;
  margin-right: 4rpx;
}

.amount {
  font-size: 72rpx;
  font-weight: bold;
}

.overview-detail {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-value {
  font-size: 40rpx;
  font-weight: bold;
}

.detail-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.detail-line {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active {
  background: #1890ff;
  color: #fff;
  font-weight: 500;
}

/* 账单列表 */
.bill-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.bill-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.bill-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.bill-type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.bill-type-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.bill-type-icon.property {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
}

.bill-type-icon.water {
  background: linear-gradient(135deg, #13c2c2 0%, #5cdbd3 100%);
}

.bill-type-icon.electricity {
  background: linear-gradient(135deg, #faad14 0%, #ffd666 100%);
}

.bill-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bill-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.bill-room {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.bill-status-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.bill-status-badge.unpaid {
  background: #fff1e6;
  color: #ff6b00;
}

.bill-status-badge.paid {
  background: #f6ffed;
  color: #52c41a;
}

/* 账单信息 */
.bill-body {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.bill-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

/* 账单底部 */
.bill-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount-label {
  font-size: 24rpx;
  color: #999;
}

.amount-value {
  font-size: 40rpx;
  font-weight: bold;
}

.amount-value.unpaid {
  color: #ff4d4f;
}

.amount-value.paid {
  color: #52c41a;
}

.action-btn {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn-text {
  color: #1890ff;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon .iconfont {
  font-size: 80rpx;
  color: #ccc;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
