/* 访客通行页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

/* 内容区域 */
.content {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 邀请卡片 */
.invite-card {
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(114, 46, 209, 0.3);
}

.invite-main {
  display: flex;
  align-items: center;
}

.invite-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.invite-info {
  flex: 1;
  margin-left: 24rpx;
}

.invite-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.invite-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.invite-btn {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #722ed1;
  font-weight: 500;
}

/* 统计 */
.stats-row {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #722ed1;
  margin-bottom: 4rpx;
}

.stat-text {
  font-size: 22rpx;
  color: #999;
}

/* 记录列表 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #722ed1;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.record-left {
  display: flex;
  align-items: center;
}

.visitor-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.visitor-info {
  margin-left: 16rpx;
}

.visitor-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.visitor-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.record-right {
  text-align: right;
}

.pass-status {
  display: block;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
}

.pass-status.active {
  background: #f6ffed;
  color: #52c41a;
}

.pass-status.used {
  background: #f5f5f5;
  color: #999;
}

.pass-code {
  display: block;
  font-size: 22rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
  max-height: 60vh;
}

.modal-footer {
  padding: 20rpx 32rpx 40rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.input-label text:last-child {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #722ed1;
}

/* 目的选择 */
.purpose-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.purpose-item {
  padding: 16rpx;
  text-align: center;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.purpose-item.active {
  background: #f3e8ff;
  border-color: #722ed1;
  color: #722ed1;
  font-weight: 500;
}

/* 有效期选择 */
.expire-grid {
  display: flex;
  gap: 16rpx;
}

.expire-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.expire-item.active {
  background: #f3e8ff;
  border-color: #722ed1;
  color: #722ed1;
  font-weight: 500;
}

/* 提交按钮 */
.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(114, 46, 209, 0.3);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

/* 通行码弹窗 */
.code-modal {
  text-align: center;
}

.code-success {
  padding: 40rpx 0 20rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: #52c41a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 60rpx;
  color: #fff;
}

.success-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.code-display {
  margin: 32rpx 0;
}

.code-number {
  display: inline-block;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
  border-radius: 16rpx;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
}

.code-tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tips-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.tips-icon {
  font-size: 28rpx;
}

.visitor-summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}
