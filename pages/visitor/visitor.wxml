<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <text class="iconfont icon-back"></text>
      </view>
      <text class="nav-title">访客通行</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 一键邀请 -->
    <view class="invite-card">
      <view class="invite-main" bindtap="showAddVisitor">
        <view class="invite-icon">
          <text>👤</text>
        </view>
        <view class="invite-info">
          <text class="invite-title">邀请访客</text>
          <text class="invite-desc">填写访客信息，生成通行码</text>
        </view>
        <view class="invite-btn">去邀请</view>
      </view>
    </view>

    <!-- 统计 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.activeCount}}</text>
        <text class="stat-text">有效通行</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.todayCount}}</text>
        <text class="stat-text">今日访客</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.totalCount}}</text>
        <text class="stat-text">本月总计</text>
      </view>
    </view>

    <!-- 通行记录 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">通行记录</text>
        <text class="section-more" bindtap="goToHistory">查看全部 ></text>
      </view>
      
      <view class="record-list">
        <view class="record-item" wx:for="{{records}}" wx:key="id">
          <view class="record-left">
            <view class="visitor-avatar">
              <text>{{item.visitorName ? item.visitorName.substr(0,1) : '?'}}</text>
            </view>
            <view class="visitor-info">
              <text class="visitor-name">{{item.visitorName || '访客'}}</text>
              <text class="visitor-meta">{{item.visitPurpose || '来访'}} · {{item.visitTime}}</text>
            </view>
          </view>
          <view class="record-right">
            <text class="pass-status {{item.status}}">{{item.statusText || '已使用'}}</text>
            <text class="pass-code" wx:if="{{item.passCode}}">{{item.passCode}}</text>
          </view>
        </view>
        
        <view class="empty-state" wx:if="{{records.length === 0}}">
          <view class="empty-icon">📭</view>
          <text class="empty-text">暂无通行记录</text>
          <text class="empty-sub">邀请访客后会自动生成记录</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 邀请访客弹窗 -->
<view class="modal" wx:if="{{showModal}}" bindtap="hideModal">
  <view class="modal-content" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">邀请访客</text>
      <text class="modal-close" bindtap="hideModal">×</text>
    </view>
    
    <view class="modal-body">
      <!-- 访客姓名 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">👤</text>
          <text>访客姓名</text>
        </view>
        <input 
          class="input-field" 
          placeholder="请输入访客姓名" 
          value="{{formData.visitorName}}" 
          bindinput="onInput" 
          data-field="visitorName"
        />
      </view>

      <!-- 访客电话 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📞</text>
          <text>联系电话</text>
        </view>
        <input 
          class="input-field" 
          type="number" 
          placeholder="请输入手机号" 
          value="{{formData.visitorPhone}}" 
          bindinput="onInput" 
          data-field="visitorPhone"
        />
      </view>

      <!-- 访问目的 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📋</text>
          <text>访问目的</text>
        </view>
        <view class="purpose-grid">
          <view 
            class="purpose-item {{formData.visitPurpose === item ? 'active' : ''}}" 
            wx:for="{{purposes}}" 
            wx:key="index"
            bindtap="selectPurpose"
            data-purpose="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <!-- 有效期 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">⏰</text>
          <text>有效期</text>
        </view>
        <view class="expire-grid">
          <view 
            class="expire-item {{formData.expireHours === item.value ? 'active' : ''}}" 
            wx:for="{{expireOptions}}" 
            wx:key="index"
            bindtap="selectExpire"
            data-expire="{{item.value}}"
          >
            {{item.label}}
          </view>
        </view>
      </view>
    </view>
    
    <view class="modal-footer">
      <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitVisitor">
        <text>生成通行码</text>
      </view>
    </view>
  </view>
</view>

<!-- 通行码展示弹窗 -->
<view class="modal" wx:if="{{showCodeModal}}" bindtap="hideCodeModal">
  <view class="modal-content code-modal" catchtap="preventBubble">
    <view class="code-success">
      <view class="success-icon">✓</view>
      <text class="success-text">通行码已生成</text>
    </view>
    
    <view class="code-display">
      <text class="code-number">{{generatedCode}}</text>
    </view>
    
    <view class="code-tips">
      <view class="tips-item">
        <text class="tips-icon">💡</text>
        <text>请将此码告知访客</text>
      </view>
      <view class="tips-item">
        <text class="tips-icon">🏠</text>
        <text>访客到小区门口出示即可</text>
      </view>
    </view>
    
    <view class="visitor-summary">
      <text>访客：{{formData.visitorName || '未填写'}}</text>
      <text>有效期至：{{expireText}}</text>
    </view>
    
    <view class="modal-footer">
      <view class="submit-btn" bindtap="hideCodeModal">
        <text>知道了</text>
      </view>
    </view>
  </view>
</view>
