/* 在线报修页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

/* 内容区域 */
.content {
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 36rpx;
}

/* 类型选择 */
.type-section {
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 24rpx;
  color: #666;
}

.type-item.active .type-name {
  color: #1890ff;
  font-weight: 500;
}

/* 描述区域 */
.desc-section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-tip {
  font-size: 22rpx;
  color: #999;
}

.textarea-wrapper {
  position: relative;
}

.desc-textarea {
  width: 100%;
  height: 180rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid #e8e8e8;
}

.desc-textarea:focus {
  border-color: #1890ff;
}

.placeholder {
  color: #b3b3b3;
  font-size: 28rpx;
}

.word-count {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: #ccc;
}

/* 预约时间 */
.time-section {
  margin-bottom: 36rpx;
}

.time-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.time-grid::-webkit-scrollbar {
  display: none;
}

.time-item {
  min-width: 120rpx;
  padding: 20rpx 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.time-item.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.time-day {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.time-item.active .time-day {
  color: #1890ff;
  font-weight: 500;
}

.time-date {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.time-slots {
  display: flex;
  gap: 16rpx;
}

.slot-item {
  flex: 1;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.slot-item.active {
  background: #e6f7ff;
  border-color: #1890ff;
  color: #1890ff;
  font-weight: 500;
}

/* 联系方式 */
.contact-section {
  margin-bottom: 0;
}

.contact-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.contact-phone {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.contact-tip {
  font-size: 22rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

/* 提交按钮 */
.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.submit-btn.disabled text {
  color: #fff;
}

/* 报修记录 */
.records-section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-category {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.category-icon {
  font-size: 32rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.record-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.record-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.record-status.processing {
  background: #e6f7ff;
  color: #1890ff;
}

.record-status.completed {
  background: #f6ffed;
  color: #52c41a;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.record-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-info {
  display: flex;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.info-item .iconfont {
  margin-right: 6rpx;
  font-size: 22rpx;
}

.record-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon text {
  font-size: 60rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}
