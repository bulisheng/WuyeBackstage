/* 报修详情页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

/* 内容区域 */
.content {
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #1890ff 0%, #70b3f5 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  color: #fff;
}

.status-card.completed {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.status-card.pending {
  background: linear-gradient(135deg, #faad14 0%, #ffd666 100%);
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.status-icon .iconfont {
  font-size: 50rpx;
  color: #fff;
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.status-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 10rpx 0 8rpx;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.status-tag.ack {
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
}

.status-tag.muted {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.85);
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-header {
  margin-bottom: 24rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  margin-left: 20rpx;
}

.info-value.description {
  flex: 1;
  text-align: left;
  line-height: 1.6;
}

.info-value.phone {
  color: #1890ff;
}

.handler-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.call-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.call-btn .iconfont {
  font-size: 24rpx;
  color: #fff;
}

/* 进度卡片 */
.progress-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.progress-header {
  margin-bottom: 30rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.timeline {
  display: flex;
  flex-direction: column;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item:not(:last-child)::before {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 48rpx;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
}

.timeline-item.active:not(:last-child)::before {
  background: linear-gradient(to bottom, #52c41a 0%, #95de64 100%);
}

.timeline-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.timeline-item.active .timeline-dot {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.timeline-dot .iconfont {
  font-size: 24rpx;
  color: #fff;
}

.timeline-content {
  flex: 1;
  padding-top: 8rpx;
}

.timeline-title {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.timeline-item.active .timeline-title {
  color: #333;
  font-weight: 500;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

/* 温馨提示 */
.tips-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-header {
  margin-bottom: 20rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-item {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
}
