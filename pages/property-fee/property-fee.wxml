<view class="page">
  <view class="header">
    <view class="header-content">
      <text class="header-title">缴费中心</text>
    </view>
  </view>

  <view class="main-content">
    <!-- 账户信息 -->
    <view class="account-card card">
      <view class="account-info">
        <view class="account-left">
          <text class="account-label">账户信息</text>
          <text class="account-room">{{user.room}}</text>
        </view>
        <view class="account-right">
          <text class="account-label">欠费金额</text>
          <text class="account-amount">¥{{unpaidAmount}}</text>
        </view>
      </view>
    </view>

    <!-- 待缴费列表 -->
    <view class="fee-section">
      <view class="section-header">
        <text class="section-title">待缴费</text>
        <text class="section-count">{{unpaidList.length}}笔</text>
      </view>

      <view class="fee-list">
        <view class="fee-item card {{item.selected ? 'selected' : ''}}" 
              wx:for="{{unpaidList}}" 
              wx:key="id"
              bindtap="toggleSelect" 
              data-id="{{item.id}}">
          <view class="fee-left">
            <view class="checkbox {{item.selected ? 'checked' : ''}}">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
            <view class="fee-info">
              <text class="fee-type">{{item.type}}</text>
              <text class="fee-period">{{item.period}}</text>
            </view>
          </view>
          <view class="fee-right">
            <text class="fee-amount">¥{{item.amount}}</text>
          </view>
        </view>
      </view>

      <!-- 已缴费历史 -->
      <view class="section-header mt-30">
        <text class="section-title">已缴费</text>
        <text class="section-count">{{paidList.length}}笔</text>
      </view>

      <view class="fee-list">
        <view class="fee-item card paid" 
              wx:for="{{paidList}}" 
              wx:key="id"
              bindtap="viewDetail" 
              data-item="{{item}}">
          <view class="fee-left">
            <view class="paid-icon">✓</view>
            <view class="fee-info">
              <text class="fee-type">{{item.type}}</text>
              <text class="fee-period">{{item.period}}</text>
            </view>
          </view>
          <view class="fee-right">
            <text class="fee-amount paid-amount">¥{{item.amount}}</text>
            <text class="paid-date">{{item.paidDate}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{selectedAmount > 0}}">
    <view class="bottom-left">
      <text class="select-info">已选{{selectedCount}}项</text>
      <text class="select-amount">合计: ¥{{selectedAmount}}</text>
    </view>
    <view class="bottom-right">
      <button class="pay-btn" bindtap="goToPay">立即支付</button>
    </view>
  </view>
</view>
