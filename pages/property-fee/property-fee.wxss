.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.header {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.main-content {
  padding: 0 24rpx;
  margin-top: -20rpx;
}

.account-card {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  padding: 30rpx;
}

.account-info {
  display: flex;
  justify-content: space-between;
}

.account-left,
.account-right {
  display: flex;
  flex-direction: column;
}

.account-label {
  font-size: 26rpx;
  opacity: 0.8;
}

.account-room {
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 8rpx;
}

.account-amount {
  font-size: 48rpx;
  font-weight: bold;
  text-align: right;
}

.fee-section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-count {
  font-size: 26rpx;
  color: #999999;
}

.fee-list {
  margin-bottom: 20rpx;
}

.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  transition: all 0.3s;
}

.fee-item.selected {
  background: #f0f9ff;
  border: 2rpx solid #1890ff;
}

.fee-item.paid {
  opacity: 0.8;
}

.fee-left {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #dddddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.3s;
}

.checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
  color: #ffffff;
}

.paid-icon {
  width: 44rpx;
  height: 44rpx;
  background: #52c41a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  margin-right: 20rpx;
}

.fee-info {
  display: flex;
  flex-direction: column;
}

.fee-type {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.fee-period {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.fee-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.fee-amount {
  font-size: 34rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.fee-amount.paid-amount {
  color: #52c41a;
}

.paid-date {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.bottom-left {
  display: flex;
  flex-direction: column;
}

.select-info {
  font-size: 24rpx;
  color: #999999;
}

.select-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-top: 4rpx;
}

.pay-btn {
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  color: #ffffff;
  font-size: 32rpx;
  padding: 24rpx 60rpx;
  border-radius: 44rpx;
  border: none;
}
