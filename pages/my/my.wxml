<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <text class="iconfont icon-back"></text>
      </view>
      <text class="nav-title">我的</text>
    </view>
  </view>

  <view class="header-bg">
    <view class="header-content">
      <image class="avatar" src="{{user.avatar}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{user.name}}</text>
        <text class="user-phone">{{user.phone}}</text>
      </view>
    </view>
  </view>

  <view class="main-content">
    <!-- 房屋信息 -->
    <view class="house-card card">
      <view class="house-header">
        <text class="house-title">我的房屋</text>
      </view>
      <view class="house-info">
        <view class="house-item">
          <text class="house-label">小区</text>
          <text class="house-value">阳光花园小区</text>
        </view>
        <view class="house-item">
          <text class="house-label">楼栋</text>
          <text class="house-value">A栋</text>
        </view>
        <view class="house-item">
          <text class="house-label">房号</text>
          <text class="house-value">101室</text>
        </view>
        <view class="house-item">
          <text class="house-label">建筑面积</text>
          <text class="house-value">120㎡</text>
        </view>
      </view>
    </view>

    <!-- 费用统计 -->
    <view class="stats-card card">
      <view class="stats-header">
        <text class="stats-title">费用统计</text>
      </view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value text-danger">¥{{unpaidAmount}}</text>
          <text class="stats-label">待缴金额</text>
        </view>
        <view class="stats-item">
          <text class="stats-value text-success">¥{{paidAmount}}</text>
          <text class="stats-label">已缴金额</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{repairCount}}</text>
          <text class="stats-label">报修次数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{complaintCount}}</text>
          <text class="stats-label">投诉建议</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section card">
      <view class="menu-item" bindtap="goToRepair">
        <view class="menu-left">
          <text class="menu-icon">🔧</text>
          <text class="menu-text">我的报修</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToComplaint">
        <view class="menu-left">
          <text class="menu-icon">📝</text>
          <text class="menu-text">投诉建议</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToFee">
        <view class="menu-left">
          <text class="menu-icon">💰</text>
          <text class="menu-text">缴费记录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-section card">
      <view class="menu-item" bindtap="callService">
        <view class="menu-left">
          <text class="menu-icon">📞</text>
          <text class="menu-text">物业热线</text>
        </view>
        <view class="menu-right">
          <text class="phone-number">400-888-8888</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-left">
          <text class="menu-icon">ℹ</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
