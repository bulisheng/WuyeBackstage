.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-content {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 20rpx;
}

.header-bg {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 60rpx 30rpx 100rpx;
}

.header-content {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.main-content {
  margin-top: -60rpx;
  padding: 0 24rpx 30rpx;
}

.house-card {
  padding: 30rpx;
}

.house-header {
  margin-bottom: 20rpx;
}

.house-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.house-info {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.house-item {
  display: flex;
  flex-direction: column;
}

.house-label {
  font-size: 24rpx;
  color: #999999;
}

.house-value {
  font-size: 28rpx;
  color: #333333;
  margin-top: 6rpx;
}

/* 统计卡片 */
.stats-card {
  padding: 30rpx;
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
}

.text-danger {
  color: #ff4d4f;
}

.text-success {
  color: #52c41a;
}

.stats-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 菜单 */
.menu-section {
  padding: 0;
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.phone-number {
  font-size: 28rpx;
  color: #1890ff;
  margin-right: 10rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}
