<block wx:if="{{isAdmin&&isLoad}}">
	<cmpt-comm-list id="cmpt-comm-list" source="admin" type="admin-customer-list" search="{{search}}" _menus="{{sortMenus}}" _items="{{sortItems}}" pulldownType="{{['list','modal','list']}}" route="admin/customer_list" sortMenusDefaultIndex="0" topBottom="50" placeholder="搜索问题,标题" bind:list="bindCommListCmpt">
		<view class="admin-comm-list">
			<view wx:if="{{dataList && dataList.total}}" class="load text-grey">共有{{dataList.total}}条符合条件记录</view>
			<view class="item" wx:for="{{dataList.list}}" wx:key="_id">
				<view class="no">{{index+1}}</view>
				<view class="header">
					<view class="left text-cut">{{item.TICKET_TITLE}}</view>
					<view wx:if="{{item.TICKET_STATUS==0}}" class="right text-orange">「待回复」</view>
					<view wx:elif="{{item.TICKET_STATUS==1}}" class="right text-green">「已回复」</view>
					<view wx:elif="{{item.TICKET_STATUS==2}}" class="right text-blue">「已关闭」</view>
					<view wx:else class="right text-grey">「已归档」</view>
				</view>
				<view class="info">
					<view class="info-item"><view class="title">问题</view><view class="mao">：</view><view class="content">{{item.TICKET_DESC}}</view></view>
					<view class="info-item"><view class="title">时间</view><view class="mao">：</view><view class="content">{{item.TICKET_ADD_TIME}}</view></view>
					<view class="oprt"><view bindtap="url" data-url="../detail/admin_customer_detail?id={{item._id}}" class="btn margin-right-s">查看详情</view></view>
				</view>
			</view>
		</view>
		<import src="../../../../../../tpls/public/list_load_tpl.wxml" />
		<template is="listLoadTpl" data="{{skin:'text-grey',dataList}}" />
	</cmpt-comm-list>
</block>
