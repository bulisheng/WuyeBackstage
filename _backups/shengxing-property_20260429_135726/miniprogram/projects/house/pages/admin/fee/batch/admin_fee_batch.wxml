<view class="page">
	<view class="admin-comm-list">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item"><view class="title">批量格式</view><view class="mao">：</view><view class="content">标题|房号|类型|金额|截止日期|说明</view></view>
				<view class="info-item"><view class="title">说明</view><view class="mao">：</view><view class="content">每行一条账单，空行会忽略</view></view>
				<view class="info-item"><view class="title">内容</view><view class="mao">：</view><view class="content"><textarea value="{{batchText}}" bindinput="bindInput"></textarea></view></view>
				<view class="info-item">
					<view class="title">操作</view><view class="mao">：</view>
					<view class="content">
						<button bindtap="bindSubmitTap" size="mini" class="margin-right-xs">提交账单</button>
						<button bindtap="bindRemindTap" size="mini">批量催缴</button>
					</view>
				</view>
			</view>
		</view>
	</view>
</view>
