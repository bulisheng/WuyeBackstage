<view class="page">
	<view wx:for="{{communities}}" wx:key="name" data-index="{{index}}" bindtap="selectCommunity" class="community-row">
		<text>{{item.name}}</text>
		<text wx:if="{{item.current}}" class="current">当前小区</text>
	</view>
	<button class="add-btn" bindtap="addCommunity">+ 添加小区</button>
</view>
