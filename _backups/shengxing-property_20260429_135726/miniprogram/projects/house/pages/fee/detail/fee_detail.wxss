page { background: #f7f8fa; }
.page { padding: 24rpx; }
.detail-card { background: #fff; border-radius: 18rpx; padding: 36rpx 28rpx; position: relative; }
.type { font-size: 28rpx; font-weight: 700; color: #202124; }
.amount { margin-top: 32rpx; font-size: 54rpx; font-weight: 800; color: #111827; }
.badge { position: absolute; top: 88rpx; right: 28rpx; color: #ff5b55; border: 1rpx solid #ffb4ad; border-radius: 22rpx; padding: 6rpx 16rpx; font-size: 22rpx; }
.rows { margin-top: 34rpx; }
.rows view { display: flex; justify-content: space-between; padding: 16rpx 0; color: #667085; font-size: 25rpx; }
.rows view text:last-child { color: #333b46; text-align: right; max-width: 420rpx; }
.rows .red text { color: #ff5b55 !important; }
.tip { margin-top: 24rpx; background: #f7f8fa; border-radius: 10rpx; padding: 18rpx; color: #8b95a1; font-size: 23rpx; }
.primary { margin-top: 34rpx; height: 88rpx; line-height: 88rpx; border-radius: 44rpx; background: #13b35d; color: #fff; font-size: 30rpx; }
