<view class="page">
	<view class="detail-card">
		<view class="type">{{detail?detail.FEE_TITLE:'物业费'}}</view>
		<view class="amount">¥{{detail&&detail.FEE_OBJ?detail.FEE_OBJ.amount:'0.00'}}</view>
		<text class="badge">{{detail&&detail.FEE_STATUS==0?'待缴费':'已缴费'}}</text>
		<view class="rows">
			<view><text>账单类型</text><text>{{detail&&detail.FEE_OBJ?detail.FEE_OBJ.billType:''}}</text></view>
			<view><text>房屋地址</text><text>{{detail&&detail.FEE_OBJ?detail.FEE_OBJ.houseName:''}}</text></view>
			<view><text>账单说明</text><text>{{detail?detail.FEE_DESC:''}}</text></view>
			<view><text>应缴金额</text><text>¥{{detail&&detail.FEE_OBJ?detail.FEE_OBJ.amount:'0.00'}}</text></view>
			<view class="red"><text>截止时间</text><text>{{detail&&detail.FEE_OBJ?detail.FEE_OBJ.dueDate:'-'}}</text></view>
		</view>
		<view class="tip">如有疑问，请联系物业客服</view>
	</view>
	<button class="primary" bindtap="pay">微信支付</button>
</view>
