page { background: #f7f8fa; }
.page { padding-bottom: 120rpx; }
.cover { width: 100%; height: 520rpx; }
.card { margin: -24rpx 24rpx 0; background: #fff; border-radius: 20rpx; padding: 28rpx; position: relative; }
.title { font-size: 34rpx; font-weight: 800; color: #202124; }
.price { margin-top: 18rpx; color: #ff4d3d; font-size: 42rpx; font-weight: 800; }
.price text { color: #a0a7b0; font-size: 24rpx; text-decoration: line-through; margin-left: 16rpx; }
.tags { margin-top: 22rpx; }
.tags text { color: #667085; background: #f2f4f7; border-radius: 8rpx; padding: 8rpx 12rpx; margin-right: 12rpx; font-size: 22rpx; }
.row { display: flex; justify-content: space-between; align-items: center; margin-top: 34rpx; font-size: 27rpx; color: #202124; }
.spec { display: inline-block; padding: 12rpx 26rpx; border-radius: 28rpx; background: #f2f4f7; margin-left: 16rpx; }
.spec.active { background: #e8f8ef; color: #13b35d; }
.step { display: flex; align-items: center; gap: 20rpx; }
.step button { width: 48rpx; height: 48rpx; line-height: 44rpx; padding: 0; border-radius: 50%; background: #f2f4f7; }
.bar { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; padding: 18rpx 24rpx 34rpx; display: flex; gap: 18rpx; }
.bar button { flex: 1; height: 78rpx; line-height: 78rpx; border-radius: 42rpx; font-size: 28rpx; color: #fff; }
.cart { background: #13b35d; }
.buy { background: #ff8a00; }
