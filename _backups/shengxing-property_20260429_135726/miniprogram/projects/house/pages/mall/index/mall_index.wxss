page { background: #f7f8fa; }
.page { padding: 24rpx; }
.search { height: 64rpx; border-radius: 32rpx; background: #fff; color: #9aa0a6; display: flex; align-items: center; padding: 0 24rpx; font-size: 25rpx; }
.search text:first-child { margin-right: 10rpx; }
.cates { white-space: nowrap; margin: 26rpx 0 18rpx; }
.cates text { display: inline-block; margin-right: 42rpx; color: #667085; font-size: 26rpx; }
.cates .active { color: #13b35d; font-weight: 800; }
.good { display: flex; background: #fff; border-radius: 16rpx; padding: 18rpx; margin-bottom: 18rpx; }
.good image { width: 172rpx; height: 172rpx; border-radius: 12rpx; margin-right: 20rpx; }
.info { flex: 1; min-width: 0; }
.name { font-size: 29rpx; color: #202124; font-weight: 700; margin: 8rpx 0 14rpx; }
.info > text { color: #ff6b2c; background: #fff4ec; border-radius: 6rpx; padding: 4rpx 10rpx; font-size: 21rpx; }
.bottom { display: flex; align-items: center; margin-top: 32rpx; }
.bottom view { color: #ff4d3d; font-size: 31rpx; font-weight: 800; margin-right: 20rpx; }
.bottom text { color: #9aa0a6; font-size: 22rpx; flex: 1; }
.bottom button { width: 48rpx; height: 48rpx; line-height: 48rpx; padding: 0; border-radius: 50%; background: #fff; color: #13b35d; border: 1rpx solid #13b35d; font-size: 30rpx; }
