page { background: #f7f8fa; }
.page { padding: 20rpx 24rpx 80rpx; }
.tabs { display: flex; justify-content: center; gap: 72rpx; height: 72rpx; color: #8b95a1; font-size: 28rpx; }
.tabs view { line-height: 72rpx; }
.tabs .active { color: #13b35d; font-weight: 800; border-bottom: 6rpx solid #13b35d; }
.form-card, .record { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-top: 18rpx; }
.field, .switch-row { display: flex; justify-content: space-between; align-items: center; min-height: 72rpx; font-size: 27rpx; color: #202124; }
.field text:last-child { color: #8b95a1; font-size: 25rpx; }
textarea { width: 100%; height: 180rpx; background: #fafafa; border-radius: 12rpx; padding: 20rpx; box-sizing: border-box; font-size: 26rpx; margin-top: 14rpx; }
.upload { margin-top: 20rpx; width: 150rpx; height: 150rpx; border-radius: 12rpx; background: #fafafa; color: #8b95a1; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 22rpx; }
.upload .icon-camera { font-size: 42rpx; margin-bottom: 10rpx; }
.primary { margin-top: 28rpx; height: 86rpx; line-height: 86rpx; border-radius: 44rpx; background: #13b35d; color: #fff; font-size: 30rpx; }
.section-title { margin: 34rpx 0 8rpx; font-size: 30rpx; font-weight: 800; }
.record { display: flex; justify-content: space-between; align-items: center; }
.record view view { font-size: 27rpx; font-weight: 700; margin-bottom: 12rpx; }
.record text { font-size: 23rpx; color: #8b95a1; }
.record .status { color: #f59e0b; background: #fff7e8; padding: 6rpx 14rpx; border-radius: 18rpx; }
