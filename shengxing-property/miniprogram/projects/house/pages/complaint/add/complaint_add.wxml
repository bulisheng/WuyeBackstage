<view class="page">
	<view class="tabs">
		<view class="{{tab==='投诉'?'active':''}}" data-tab="投诉" bindtap="setTab">投诉</view>
		<view class="{{tab==='建议'?'active':''}}" data-tab="建议" bindtap="setTab">建议</view>
	</view>
	<view class="form-card">
		<view class="field"><text>选择类别</text><text>环境卫生 ></text></view>
		<input placeholder="请输入标题" value="{{formTitle}}" bindinput="bindInput" data-item="formTitle" />
		<textarea placeholder="小区设施哪里不好、希望怎么处理..." maxlength="500" value="{{formDesc}}" bindinput="bindInput" data-item="formDesc"></textarea>
		<view class="upload"><text class="icon-camera"></text><view>上传图片（0/5）</view></view>
		<view class="switch-row"><text>匿名提交</text><switch checked="{{anonymous}}" bindchange="toggleAnonymous" color="#13b35d" /></view>
	</view>
	<button class="primary" bindtap="submit">提交</button>
	<view class="section-title">我的记录</view>
	<view wx:for="{{records}}" wx:key="title" class="record">
		<view>
			<view>{{item.title}}</view>
			<text>提交时间：{{item.time}}</text>
		</view>
		<text class="status">{{item.status}}</text>
	</view>
</view>
