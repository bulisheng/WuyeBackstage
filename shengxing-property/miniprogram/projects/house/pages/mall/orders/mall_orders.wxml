<view class="page">
	<view class="tabs"><text class="active">全部</text><text>待付款</text><text>待发货</text><text>待收货</text><text>已完成</text></view>
	<view wx:for="{{orders}}" wx:key="no" class="order">
		<view class="top"><text>订单号：{{item.no}}</text><text class="status">{{item.status}}</text></view>
		<view class="body">
			<image src="{{item.pic}}" mode="aspectFill" />
			<view><view>{{item.name}}</view><text>共1件</text></view>
			<text>¥{{item.price}}</text>
		</view>
		<view class="pay">实付：¥{{item.price}}</view>
	</view>
	<view class="empty">没有更多了</view>
</view>
