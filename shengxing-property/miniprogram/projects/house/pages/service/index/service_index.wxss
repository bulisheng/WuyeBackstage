page { background: #f7f8fa; }
.page { padding: 24rpx; }
.service-card { height: 210rpx; background: #e8f7ef; border-radius: 18rpx; padding: 20rpx; display: flex; margin-bottom: 22rpx; overflow: hidden; }
.service-card:nth-child(2) { background: #eaf4ff; }
.service-card image { width: 210rpx; height: 170rpx; border-radius: 14rpx; margin-right: 24rpx; }
.title { margin-top: 12rpx; font-size: 34rpx; font-weight: 800; color: #18794e; }
.service-card text { display: block; color: #4b5563; font-size: 24rpx; margin-top: 12rpx; }
button { margin: 20rpx 0 0; width: 150rpx; height: 52rpx; line-height: 52rpx; border-radius: 28rpx; background: #13b35d; color: #fff; font-size: 24rpx; }
