<view class="page">
	<view class="tabs">
		<view class="{{tab==='todo'?'active':''}}" data-tab="todo" bindtap="setTab">待缴费</view>
		<view class="{{tab==='paid'?'active':''}}" data-tab="paid" bindtap="setTab">已缴费</view>
	</view>
	<block wx:if="{{tab==='todo'}}">
		<view wx:for="{{bills}}" wx:key="id" class="bill-card" bindtap="goDetail" data-id="{{item.id}}">
			<view>
				<view class="bill-title">{{item.type}}</view>
				<text wx:if="{{item.overdue}}" class="overdue">待缴费</text>
			</view>
			<view class="right">
				<view class="price">¥{{item.amount}}</view>
				<text>截止：{{item.due}}</text>
			</view>
		</view>
		<view class="total">共4笔账单，合计：<text>¥526.20</text></view>
		<button class="primary" bindtap="goDetail">去缴费</button>
	</block>
	<block wx:else>
		<view wx:for="{{paid}}" wx:key="id" class="bill-card">
			<view class="bill-title">{{item.type}}</view>
			<view class="right">
				<view>¥{{item.amount}}</view>
				<text>{{item.time}}</text>
			</view>
		</view>
		<view class="empty">没有更多了</view>
	</block>
	<view class="record" bindtap="goRecord">查看缴费记录</view>
</view>
