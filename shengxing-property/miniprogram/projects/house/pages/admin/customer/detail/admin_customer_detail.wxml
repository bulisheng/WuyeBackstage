<view wx:if="{{isLoad===null}}" class="margin-top load notexist text-l text-grey"></view>
<view wx:if="{{isLoad===false}}" class="margin-top load loading text-l text-grey"></view>

<view wx:if="{{isLoad && isAdmin}}" class="main-admin">
	<view class="admin-comm-list"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">标题</view><view class="mao">：</view><view class="content">{{detail.TICKET_TITLE}}</view></view>
		<view class="info-item"><view class="title">状态</view><view class="mao">：</view><view class="content">{{detail.statusText}}</view></view>
		<view class="info-item"><view class="title">问题</view><view class="mao">：</view><view class="content">{{detail.TICKET_DESC}}</view></view>
		<view class="info-item"><view class="title">创建时间</view><view class="mao">：</view><view class="content">{{detail.TICKET_ADD_TIME}}</view></view>
	</view></view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">操作</view><view class="mao">：</view><view class="content">
			<button bindtap="bindStatusTap" data-status="0" size="mini" class="margin-right-xs">待回复</button>
			<button bindtap="bindStatusTap" data-status="1" size="mini" class="margin-right-xs">已回复</button>
			<button bindtap="bindStatusTap" data-status="2" size="mini" class="margin-right-xs">关闭</button>
			<button bindtap="bindStatusTap" data-status="9" size="mini">归档</button>
		</view></view>
	</view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">分配处理</view><view class="mao">：</view><view class="content"></view></view>
		<view class="info-item"><view class="title">负责人</view><view class="mao">：</view><view class="content"><input value="{{edit.assigneeName}}" data-field="assigneeName" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">电话</view><view class="mao">：</view><view class="content"><input value="{{edit.assigneePhone}}" data-field="assigneePhone" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">动作</view><view class="mao">：</view><view class="content"><button bindtap="bindAssignTap" size="mini">保存分配</button></view></view>
	</view></view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">回复处理</view><view class="mao">：</view><view class="content"></view></view>
		<view class="info-item"><view class="title">回复内容</view><view class="mao">：</view><view class="content"><textarea value="{{edit.replyContent}}" data-field="replyContent" bindinput="bindInput"></textarea></view></view>
		<view class="info-item"><view class="title">动作</view><view class="mao">：</view><view class="content"><button bindtap="bindReplyTap" size="mini">提交回复</button></view></view>
	</view></view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">扩展信息</view><view class="mao">：</view></view>
		<view wx:for="{{objItems}}" wx:key="key" class="info-item"><view class="title">{{item.key}}</view><view class="mao">：</view><view class="content">{{item.value}}</view></view>
	</view></view></view>
	<view wx:if="{{formItems.length}}" class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">表单内容</view><view class="mao">：</view></view>
		<view wx:for="{{formItems}}" wx:key="title" class="info-item"><view class="title">{{item.title}}</view><view class="mao">：</view><view class="content">{{item.value}}</view></view>
	</view></view></view>
</view>
