<view wx:if="{{isLoad===null}}" class="margin-top load notexist text-l text-grey"></view>
<view wx:if="{{isLoad===false}}" class="margin-top load loading text-l text-grey"></view>

<view wx:if="{{isLoad && isAdmin}}" class="main-admin">
	<view class="admin-comm-list">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item">
					<view class="title">账单</view><view class="mao">：</view>
					<view class="content">{{detail.FEE_TITLE}}</view>
				</view>
				<view class="info-item">
					<view class="title">状态</view><view class="mao">：</view>
					<view class="content">{{detail.statusText}}</view>
				</view>
				<view class="info-item">
					<view class="title">创建时间</view><view class="mao">：</view>
					<view class="content">{{detail.FEE_ADD_TIME}}</view>
				</view>
				<view class="info-item">
					<view class="title">更新时间</view><view class="mao">：</view>
					<view class="content">{{detail.FEE_EDIT_TIME}}</view>
				</view>
			</view>
		</view>
	</view>

	<view class="admin-comm-list margin-top-s">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item"><view class="title">说明</view><view class="mao">：</view><view class="content">{{detail.FEE_DESC}}</view></view>
				<view class="info-item"><view class="title">房号</view><view class="mao">：</view><view class="content">{{detail.FEE_OBJ.houseName}}</view></view>
				<view class="info-item"><view class="title">金额</view><view class="mao">：</view><view class="content">¥{{detail.FEE_OBJ.amount}}</view></view>
				<view class="info-item"><view class="title">截止日期</view><view class="mao">：</view><view class="content">{{detail.FEE_OBJ.dueDate || '无'}}</view></view>
				<view class="info-item"><view class="title">支付时间</view><view class="mao">：</view><view class="content">{{detail.FEE_OBJ.payTime || '未支付'}}</view></view>
			</view>
		</view>
	</view>

	<view class="admin-comm-list margin-top-s">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item"><view class="title">编辑账单</view><view class="mao">：</view><view class="content"></view></view>
				<view class="info-item"><view class="title">标题</view><view class="mao">：</view><view class="content"><input value="{{edit.title}}" data-field="title" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">房号</view><view class="mao">：</view><view class="content"><input value="{{edit.houseName}}" data-field="houseName" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">类型</view><view class="mao">：</view><view class="content"><input value="{{edit.billType}}" data-field="billType" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">金额</view><view class="mao">：</view><view class="content"><input value="{{edit.amount}}" data-field="amount" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">截止</view><view class="mao">：</view><view class="content"><input value="{{edit.dueDate}}" data-field="dueDate" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">说明</view><view class="mao">：</view><view class="content"><textarea value="{{edit.desc}}" data-field="desc" bindinput="bindInput"></textarea></view></view>
				<view class="info-item">
					<view class="title">保存</view><view class="mao">：</view>
					<view class="content"><button bindtap="bindSaveTap" size="mini">保存账单</button></view>
				</view>
			</view>
		</view>
	</view>

	<view class="admin-comm-list margin-top-s">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item"><view class="title">催缴记录</view><view class="mao">：</view><view class="content"></view></view>
				<view class="info-item"><view class="title">方式</view><view class="mao">：</view><view class="content"><input value="{{reminder.method}}" data-group="reminder" data-field="method" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">结果</view><view class="mao">：</view><view class="content"><input value="{{reminder.result}}" data-group="reminder" data-field="result" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">负责人</view><view class="mao">：</view><view class="content"><input value="{{reminder.assigneeName}}" data-group="reminder" data-field="assigneeName" bindinput="bindInput" /></view></view>
				<view class="info-item"><view class="title">电话</view><view class="mao">：</view><view class="content"><input value="{{reminder.assigneePhone}}" data-group="reminder" data-field="assigneePhone" bindinput="bindInput" /></view></view>
				<view class="info-item">
					<view class="title">动作</view><view class="mao">：</view>
					<view class="content"><button bindtap="bindRemindTap" size="mini">生成催缴情</button></view>
				</view>
			</view>
		</view>
	</view>

	<view class="admin-comm-list margin-top-s">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item">
					<view class="title">操作</view><view class="mao">：</view>
					<view class="content">
						<button bindtap="bindStatusTap" data-status="0" size="mini" class="margin-right-xs">待缴费</button>
						<button bindtap="bindStatusTap" data-status="1" size="mini" class="margin-right-xs">已缴费</button>
						<button bindtap="bindStatusTap" data-status="9" size="mini">作废</button>
					</view>
				</view>
			</view>
		</view>
	</view>

	<view class="admin-comm-list margin-top-s">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item"><view class="title">扩展信息</view><view class="mao">：</view></view>
				<view wx:for="{{objItems}}" wx:key="key" class="info-item">
					<view class="title">{{item.key}}</view><view class="mao">：</view><view class="content">{{item.value}}</view>
				</view>
			</view>
		</view>
	</view>

	<view wx:if="{{formItems.length}}" class="admin-comm-list margin-top-s">
		<view class="item">
			<view class="info" style="min-height: unset;">
				<view class="info-item"><view class="title">表单内容</view><view class="mao">：</view></view>
				<view wx:for="{{formItems}}" wx:key="title" class="info-item">
					<view class="title">{{item.title}}</view><view class="mao">：</view><view class="content">{{item.value}}</view>
				</view>
			</view>
		</view>
	</view>
</view>
