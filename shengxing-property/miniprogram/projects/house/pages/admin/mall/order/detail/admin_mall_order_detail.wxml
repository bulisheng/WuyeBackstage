<view wx:if="{{isLoad===null}}" class="margin-top load notexist text-l text-grey"></view>
<view wx:if="{{isLoad===false}}" class="margin-top load loading text-l text-grey"></view>

<view wx:if="{{isLoad && isAdmin}}" class="main-admin">
	<view class="admin-comm-list"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">订单</view><view class="mao">：</view><view class="content">{{detail.ORDER_TITLE}}</view></view>
		<view class="info-item"><view class="title">状态</view><view class="mao">：</view><view class="content">{{detail.statusText}}</view></view>
		<view class="info-item"><view class="title">创建时间</view><view class="mao">：</view><view class="content">{{detail.ORDER_ADD_TIME}}</view></view>
		<view class="info-item"><view class="title">更新时间</view><view class="mao">：</view><view class="content">{{detail.ORDER_EDIT_TIME}}</view></view>
	</view></view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">商品</view><view class="mao">：</view><view class="content">{{detail.ORDER_DESC}}</view></view>
		<view class="info-item"><view class="title">金额</view><view class="mao">：</view><view class="content">¥{{detail.ORDER_OBJ.price}}</view></view>
		<view class="info-item"><view class="title">收货/备注</view><view class="mao">：</view><view class="content">{{detail.ORDER_OBJ.goodsName || '无'}}</view></view>
		<view class="info-item"><view class="title">支付时间</view><view class="mao">：</view><view class="content">{{detail.ORDER_OBJ.payTime || '未支付'}}</view></view>
	</view></view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">发货单号</view><view class="mao">：</view><view class="content"><input value="{{edit.shippingNo}}" data-field="shippingNo" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">物流公司</view><view class="mao">：</view><view class="content"><input value="{{edit.shippingCompany}}" data-field="shippingCompany" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">退款原因</view><view class="mao">：</view><view class="content"><input value="{{edit.reason}}" data-field="reason" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">退款金额</view><view class="mao">：</view><view class="content"><input value="{{edit.amount}}" data-field="amount" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">用户</view><view class="mao">：</view><view class="content"><input value="{{edit.userName}}" data-field="userName" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">商品名</view><view class="mao">：</view><view class="content"><input value="{{edit.productNames}}" data-field="productNames" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">小区</view><view class="mao">：</view><view class="content"><input value="{{edit.communityName}}" data-field="communityName" bindinput="bindInput" /></view></view>
		<view class="info-item"><view class="title">动作</view><view class="mao">：</view><view class="content">
			<button bindtap="bindShipTap" size="mini" class="margin-right-xs">发货</button>
			<button bindtap="bindRefundTap" size="mini">退款</button>
		</view></view>
	</view></view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">操作</view><view class="mao">：</view><view class="content">
			<button bindtap="bindStatusTap" data-status="0" size="mini" class="margin-right-xs">待支付</button>
			<button bindtap="bindStatusTap" data-status="1" size="mini" class="margin-right-xs">已支付</button>
			<button bindtap="bindStatusTap" data-status="2" size="mini" class="margin-right-xs">已发货</button>
			<button bindtap="bindStatusTap" data-status="3" size="mini" class="margin-right-xs">已完成</button>
			<button bindtap="bindStatusTap" data-status="4" size="mini" class="margin-right-xs">已退款</button>
			<button bindtap="bindStatusTap" data-status="9" size="mini">关闭</button>
		</view></view>
	</view></view>
	<view class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">扩展信息</view><view class="mao">：</view></view>
		<view wx:for="{{objItems}}" wx:key="key" class="info-item"><view class="title">{{item.key}}</view><view class="mao">：</view><view class="content">{{item.value}}</view></view>
	</view></view></view>
	<view wx:if="{{formItems.length}}" class="admin-comm-list margin-top-s"><view class="item"><view class="info" style="min-height: unset;">
		<view class="info-item"><view class="title">表单内容</view><view class="mao">：</view></view>
		<view wx:for="{{formItems}}" wx:key="title" class="info-item"><view class="title">{{item.title}}</view><view class="mao">：</view><view class="content">{{item.value}}</view></view>
	</view></view></view>
</view>
