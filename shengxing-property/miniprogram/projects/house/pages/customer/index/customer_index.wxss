page { background: #f7f8fa; }
.page { padding: 24rpx 24rpx 120rpx; }
.chat { min-height: 620rpx; }
.msg { display: flex; margin: 20rpx 0; }
.msg view { max-width: 520rpx; padding: 20rpx 22rpx; border-radius: 16rpx; font-size: 26rpx; line-height: 1.5; }
.bot view { background: #fff; color: #202124; }
.user { justify-content: flex-end; }
.user view { background: #13b35d; color: #fff; }
.faq { display: flex; flex-wrap: wrap; gap: 14rpx; }
.faq text { background: #fff; border-radius: 28rpx; padding: 12rpx 20rpx; color: #667085; font-size: 23rpx; }
.input-bar { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; padding: 18rpx 24rpx 34rpx; display: flex; align-items: center; gap: 16rpx; }
input { flex: 1; height: 68rpx; background: #f2f4f7; border-radius: 34rpx; padding: 0 24rpx; font-size: 26rpx; }
button { width: 138rpx; height: 68rpx; line-height: 68rpx; border-radius: 34rpx; background: #13b35d; color: #fff; font-size: 26rpx; }
