<view class="home-page">
	<view class="home-top">
		<view class="community" bindtap="url" data-url="../../community/switch/community_switch">
			<text>{{currentCommunity}}</text>
			<text class="icon-unfold"></text>
		</view>
		<view class="notice-dot" bindtap="url" data-url="../../news/index/news_index?id=1">
			<text class="icon-notice"></text>
			<text class="dot"></text>
		</view>
	</view>

	<view class="search" bindtap="url" data-url="../../search/search">
		<text class="icon-search"></text>
		<text>搜索服务、公告、活动</text>
	</view>

	<view class="banner" bindtap="url" data-url="../../news/index/news_index?id=1">
		<image src="../../../images/default_index_bg.jpg" mode="aspectFill" />
		<view class="banner-copy">
			<view>夏日社区嘉年华</view>
			<text>亲子运动 · 清凉一夏</text>
		</view>
		<view class="banner-btn">查看详情</view>
	</view>

	<view class="king">
		<view wx:for="{{quickMenus}}" wx:key="title" class="king-item" bindtap="url" data-url="{{item.url}}" data-type="{{item.type}}">
			<view class="king-icon {{item.cls}}">
				<image src="{{item.icon}}" mode="aspectFit" />
			</view>
			<text>{{item.title}}</text>
		</view>
	</view>

	<view wx:if="{{!isLogin}}" bindtap="url" data-url="../../my/edit/my_edit" class="authen"><text class="icon-safe margin-right-xs"></text>您尚未认证业主身份，点此快速进行注册认证</view>

	<view class="notice-card" bindtap="url" data-url="../../news/index/news_index?id=1">
		<text class="label">社区公告</text>
		<view class="notice-title content-cut-one">{{noticeTitle}}</view>
		<text class="icon-right"></text>
	</view>

	<view class="section-title">便民服务</view>
	<view class="tool-card">
		<view wx:for="{{lifeTools}}" wx:key="title" class="tool-item" bindtap="url" data-url="{{item.url}}" data-type="{{item.type}}">
			<text class="{{item.icon}}"></text>
			<view>{{item.title}}</view>
		</view>
	</view>

	<view class="section-title">推荐内容</view>
	<view class="feed-list">
		<view wx:for="{{feedList}}" wx:key="title" class="feed-card" bindtap="url" data-url="{{item.url}}">
			<image src="{{item.pic}}" mode="aspectFill" />
			<view class="feed-main">
				<view class="feed-title content-cut-one">{{item.title}}</view>
				<view class="feed-desc content-cut-two">{{item.desc}}</view>
				<text>{{item.ext}}</text>
			</view>
		</view>
	</view>
</view>

<block wx:if="{{skin.IS_SUB}}">
	<import src="../../tpls/menu_tpl.wxml" />
	<template is="menuTpl" data="{{curMenu:'home_index',returnHome:false}}" />
</block>
